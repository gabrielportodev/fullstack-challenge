generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Round {
  id         String      @id @default(uuid())
  status     RoundStatus @default(BETTING)
  crashPoint Float       @map("crash_point")
  serverSeed String      @map("server_seed")
  seedHash   String      @map("seed_hash")
  startedAt  DateTime?   @map("started_at")
  crashedAt  DateTime?   @map("crashed_at")
  createdAt  DateTime    @default(now()) @map("created_at")
  bets       Bet[]

  @@map("rounds")
}

model Bet {
  id                 String    @id @default(uuid())
  roundId            String    @map("round_id")
  playerId           String    @map("player_id")
  amountCents        BigInt    @map("amount_cents")
  status             BetStatus @default(PENDING)
  cashoutMultiplier  Float?    @map("cashout_multiplier")
  cashoutPayoutCents BigInt?   @map("cashout_payout_cents")
  autoCashoutMultiplier Float? @map("auto_cashout_multiplier")
  createdAt          DateTime  @default(now()) @map("created_at")
  round              Round     @relation(fields: [roundId], references: [id])

  @@map("bets")
}

enum RoundStatus {
  BETTING
  ACTIVE
  CRASHED
}

enum BetStatus {
  PENDING
  CASHED_OUT
  LOST
}
